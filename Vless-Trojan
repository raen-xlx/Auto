#!/bin/bash
set -e

# --- HELPER FUNCTIONS ---
banner() { echo -e "\n\033[1;34m$1\033[0m"; }
ok() { echo -e "\033[1;32m✅ $1\033[0m"; }
kv() { echo -e "\033[1;33m$1\033[0m $2"; }

# --- DISPLAY BANNER ---
clear
echo -e "\033[1;36m"
cat << "EOF"
          ██████╗  █████╗ ███████╗███╗   ██╗
          ██╔══██╗██╔══██╗██╔════╝████╗  ██║
          ██████╔╝███████║█████╗  ██╔██╗ ██║
          ██╔══██╗██╔══██║██╔══╝  ██║╚██╗██║
          ██║  ██║██║  ██║███████╗██║ ╚████║
          ╚═╝  ╚═╝╚═╝  ╚═╝╚══════╝╚═╝  ╚═══╝
EOF
echo -e "\033[0m"
echo -e "    \033[1;37mDEV: RAEN\033[0m | \033[1;32mAutomated Cloud Run Proxy\033[0m | \033[1;33mVER: 3.2\033[0m"
echo -e "    \033[1;35mDUAL PROTOCOL SUPPORT\033[0m"
echo -e "\033[1;34m  ----------------------------------------------------------\033[0m"

# --- Step 1: Protocol Selection ---
banner "🌐 Step 1 — Select Protocol"
echo "1) Trojan (WS)"
echo "2) Vless (WS)"
echo "3) Both (Deploy Trojan & Vless)"
read -p "Selection [1-3, default 1]: " PROTO_INPUT </dev/tty
PROTO_INPUT=${PROTO_INPUT:-1}

# --- Step 2: Service Name Configuration ---
banner "🪪 Step 2 — Service Name Configuration"
if [[ "$PROTO_INPUT" == "3" ]]; then
    read -rp "Trojan Service name [default: stsnoload-tr]: " _tr_svc </dev/tty
    TR_NAME="${_tr_svc:-stsnoload-tr}"
    TR_NAME=$(echo "$TR_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g')
    
    read -rp "Vless Service name [default: stsnoload-vl]: " _vl_svc </dev/tty
    VL_NAME="${_vl_svc:-stsnoload-vl}"
    VL_NAME=$(echo "$VL_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g')
    ok "Names set: Trojan ($TR_NAME) | Vless ($VL_NAME)"
else
    read -rp "Service name [default: stsnoload]: " _svc </dev/tty
    SERVICE_NAME="${_svc:-stsnoload}"
    SERVICE_NAME=$(echo "$SERVICE_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g')
    TR_NAME="$SERVICE_NAME"
    VL_NAME="$SERVICE_NAME"
    ok "Service name verified: $SERVICE_NAME"
fi

REGION="us-central1"

# --- Step 3: SNI Configuration ---
banner "🛡️ Step 3 — SNI Configuration"
DEFAULT_SNI="cares.paymaya.com"
read -p "Enter SNI [default: $DEFAULT_SNI]: " _sni_input </dev/tty
SNI="${_sni_input:-$DEFAULT_SNI}"

# --- Step 4: Resources (FIXED FOR MEMORY ERROR) ---
banner "🧮 Step 4 — Resources"
read -rp "CPU [1/2/4, default 1]: " _cpu </dev/tty
CPU="${_cpu:-1}"
read -rp "Memory [512Mi/1Gi/2Gi/4Gi, default 2Gi]: " _mem </dev/tty
MEMORY_RAW="${_mem:-2Gi}"

# FIX: Add 'Gi' if user types a single number like '4'
if [[ "$MEMORY_RAW" =~ ^[0-9]+$ ]]; then
    if [ "$MEMORY_RAW" -le 16 ]; then
        MEMORY="${MEMORY_RAW}Gi"
    else
        MEMORY="${MEMORY_RAW}Mi"
    fi
else
    MEMORY="$MEMORY_RAW"
fi

# FIX: Validate GCP Constraints (4 CPU needs at least 2Gi)
if [[ "$CPU" == "4" ]]; then
    if [[ "$MEMORY" == "512Mi" || "$MEMORY" == "1Gi" ]]; then
        MEMORY="2Gi"
        echo -e "\033[1;33m⚠️ Auto-adjusted Memory to 2Gi (Required for 4 CPUs)\033[0m"
    fi
fi

# --- Internal Configuration ---
PROJECT_ID=$(gcloud config get-value project)
PROJECT_NUM=$(gcloud projects describe "$PROJECT_ID" --format='value(projectNumber)')

deploy_service() {
    local TYPE=$1
    local NAME=$2
    local IMG=$3
    banner "⚙️ Deploying $TYPE..."
    gcloud run deploy "$NAME" \
        --image="$IMG" \
        --platform=managed \
        --region="$REGION" \
        --cpu="$CPU" \
        --memory="$MEMORY" \
        --no-cpu-throttling \
        --allow-unauthenticated \
        --port=8080 \
        --min-instances=1 \
        --quiet
}

# --- Deployment Logic ---
TR_URL=""
VL_URL=""

if [[ "$PROTO_INPUT" == "1" || "$PROTO_INPUT" == "3" ]]; then
    HOST_TR="${TR_NAME}-${PROJECT_NUM}.${REGION}.run.app"
    deploy_service "Trojan" "$TR_NAME" "docker.io/n4pro/tr:latest"
    TR_URL="trojan://Trojan-2025@vpn.googleapis.com:443?path=%2FN4&security=tls&type=ws&sni=${SNI}&host=${HOST_TR}#${TR_NAME}"
fi

if [[ "$PROTO_INPUT" == "2" || "$PROTO_INPUT" == "3" ]]; then
    HOST_VL="${VL_NAME}-${PROJECT_NUM}.${REGION}.run.app"
    VLESS_UUID="0c890000-4733-b20e-067f-fc341bd20000"
    deploy_service "Vless" "$VL_NAME" "docker.io/n4pro/vl:latest"
    VL_URL="vless://${VLESS_UUID}@vpn.googleapis.com:443?path=%2FN4&security=tls&encryption=none&host=${HOST_VL}&type=ws&sni=${SNI}#${VL_NAME}"
fi

# --- Final Output ---
echo -e "\n================================================"
ok "DEPLOYMENT COMPLETED"
echo "================================================"
if [ ! -z "$TR_URL" ]; then
    echo "🔗 TROJAN IMPORT LINK:"
    echo -e "\033[1;32m$TR_URL\033[0m"
    echo "------------------------------------------------"
fi
if [ ! -z "$VL_URL" ]; then
    echo "🔗 VLESS IMPORT LINK:"
    echo -e "\033[1;32m$VL_URL\033[0m"
    echo "------------------------------------------------"
fi
echo -e "\033[1;35m💡 NOTE: SPECIAL THANKS TO N4-PRO FOR THE DOCKERFILE\033[0m"
echo "================================================"
