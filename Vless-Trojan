#!/bin/bash
set -e

# --- HELPER FUNCTIONS ---
banner() { echo -e "\n\033[1;34m$1\033[0m"; }
ok() { echo -e "\033[1;32m✅ $1\033[0m"; }
kv() { echo -e "\033[1;33m$1\033[0m $2"; }

# --- MAIN LOOP ---
while true; do
    # --- DISPLAY BANNER ---
    clear
    echo -e "\033[1;36m"
    cat << "EOF"
          ██████╗  █████╗ ███████╗███╗   ██╗
          ██╔══██╗██╔══██╗██╔════╝████╗  ██║
          ██████╔╝███████║█████╗  ██╔██╗ ██║
          ██╔══██╗██╔══██║██╔══╝  ██║╚██╗██║
          ██║  ██║██║  ██║███████╗██║ ╚████║
          ╚═╝  ╚═╝╚═╝  ╚═╝╚══════╝╚═╝  ╚═══╝
EOF
    echo -e "\033[0m"
    echo -e "    \033[1;37mDEV: RAEN\033[0m | \033[1;32mAutomated Cloud Run Proxy\033[0m | \033[1;33mVER: 3.2\033[0m"
    echo -e "    \033[1;35mDUAL PROTOCOL SUPPORT\033[0m"
    echo -e "\033[1;34m  ----------------------------------------------------------\033[0m"

    # --- Step 1: Protocol Selection ---
    banner "🌐 Step 1 — Select Protocol"
    echo "1) Trojan (WS)"
    echo "2) Vless (WS)"
    echo "3) Both (Deploy Trojan & Vless)"
    echo "4) Created Service (Check Links)"
    echo "5) Delete Service (Single/All)"
    echo "6) Exit"
    read -p "Selection [1-6, default 1]: " PROTO_INPUT </dev/tty
    PROTO_INPUT=${PROTO_INPUT:-1}

    # --- OPTION 6: EXIT ---
    if [[ "$PROTO_INPUT" == "6" ]]; then
        clear
        echo -e "\033[1;32mExiting... Goodbye!\033[0m"
        exit 0
    fi

    # --- OPTION 4: CHECK SERVICES (CONFIG LINKS) ---
    if [[ "$PROTO_INPUT" == "4" ]]; then
        banner "🔍 Fetching Created Services..."
        echo "----------------------------------------------------------"
        gcloud run services list --platform=managed --region=us-central1 --format="table(metadata.name, status.address.url)" | tail -n +2 | while read -r name url; do
            hostname=$(echo $url | sed -e 's|^[^/]*//||' -e 's|/.*$||')
            echo -e "\033[1;32m✔ Service Found:\033[0m \033[1;37m$name\033[0m"
            if [[ "$name" == *"tr"* ]]; then
                CONFIG_LINK="trojan://Trojan-2025@firebase-settings.crashlytics.com:443?path=%2FN4&security=tls&type=ws&sni=cares.paymaya.com&host=${hostname}#${name}"
                echo -e "\033[1;33m🔗 Trojan Config:\033[0m"
            else
                VLESS_UUID="0c890000-4733-b20e-067f-fc341bd20000"
                CONFIG_LINK="vless://${VLESS_UUID}@firebase-settings.crashlytics.com:443?path=%2FN4&security=tls&encryption=none&host=${hostname}&type=ws&sni=cares.paymaya.com#${name}"
                echo -e "\033[1;33m🔗 Vless Config:\033[0m"
            fi
            echo -e "\033[1;34m$CONFIG_LINK\033[0m\n"
        done
        echo "----------------------------------------------------------"
        read -rp "Press [Enter] to return to main menu..." </dev/tty
        continue 
    fi

    # --- OPTION 5: DELETE SERVICES ---
    if [[ "$PROTO_INPUT" == "5" ]]; then
        banner "🗑️ Step 5 — Delete Service Management"
        echo "Fetching active services..."
        SERVICES=$(gcloud run services list --platform=managed --region=us-central1 --format="value(metadata.name)")
        
        if [ -z "$SERVICES" ]; then
            echo -e "\033[1;31m❌ No services found in this project.\033[0m"
        else
            echo -e "\033[1;33mCurrent Services:\033[0m"
            echo "$SERVICES" | sed 's/^/  • /'
            echo -e "\n\033[1;37mAction:\033[0m"
            echo "1) Delete All Services"
            echo "2) Delete One by Name"
            echo "3) Cancel"
            read -p "Selection: " DEL_OPT </dev/tty
            
            case $DEL_OPT in
                1)
                    echo -e "\n\033[1;31m⚠️ Initializing Full Cleanup...\033[0m"
                    for s in $SERVICES; do
                        echo -ne "\033[1;33m⏳ Deleting:\033[0m $s... "
                        gcloud run services delete "$s" --region=us-central1 --quiet > /dev/null 2>&1
                        echo -e "\033[1;32mDONE\033[0m"
                    done
                    banner "✨ Cleanup Finished"
                    ;;
                2)
                    read -p "Enter service name: " TARGET_SVC </dev/tty
                    if [[ -n "$TARGET_SVC" ]]; then
                        echo -ne "\033[1;33m⏳ Deleting:\033[0m $TARGET_SVC... "
                        if gcloud run services delete "$TARGET_SVC" --region=us-central1 --quiet > /dev/null 2>&1; then
                            echo -e "\033[1;32mDONE\033[0m"
                        else
                            echo -e "\033[1;31mFAILED (Not Found)\033[0m"
                        fi
                    fi
                    ;;
                *)
                    echo "Operation cancelled."
                    ;;
            esac
        fi
        read -rp "Press [Enter] to return to main menu..." </dev/tty
        continue
    fi

    # --- DEPLOYMENT FLOW ---
    PROJECT_ID=$(gcloud config get-value project)
    REGION="us-central1"
    echo -e "\n\033[1;35m--- Created Service Details ---\033[0m"
    kv "Project ID:  " "$PROJECT_ID"
    kv "Region:      " "$REGION"
    echo -e "\033[1;35m-------------------------------\033[0m"

    # --- Step 2: Service Name Configuration ---
    banner "🪪 Step 2 — Service Name Configuration"
    if [[ "$PROTO_INPUT" == "3" ]]; then
        read -rp "Trojan Service name [default: stsnoload-tr]: " _tr_svc </dev/tty
        TR_NAME="${_tr_svc:-stsnoload-tr}"
        TR_NAME=$(echo "$TR_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g')
        
        read -rp "Vless Service name [default: stsnoload-vl]: " _vl_svc </dev/tty
        VL_NAME="${_vl_svc:-stsnoload-vl}"
        VL_NAME=$(echo "$VL_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g')
        ok "Names set: Trojan ($TR_NAME) | Vless ($VL_NAME)"
    else
        read -rp "Service name [default: stsnoload]: " _svc </dev/tty
        SERVICE_NAME="${_svc:-stsnoload}"
        SERVICE_NAME=$(echo "$SERVICE_NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9-]//g')
        TR_NAME="$SERVICE_NAME"
        VL_NAME="$SERVICE_NAME"
        ok "Service name verified: $SERVICE_NAME"
    fi

    # --- Step 3: SNI Configuration ---
    banner "🛡️ Step 3 — SNI Configuration"
    DEFAULT_SNI="cares.paymaya.com"
    read -p "Enter SNI [default: $DEFAULT_SNI]: " _sni_input </dev/tty
    SNI="${_sni_input:-$DEFAULT_SNI}"

    # --- Step 4: Resources ---
    banner "🧮 Step 4 — Resources"
    read -rp "CPU [1/2/4, default 1]: " _cpu </dev/tty
    CPU="${_cpu:-1}"
    read -rp "Memory [512Mi/1Gi/2Gi/4Gi, default 2Gi]: " _mem </dev/tty
    MEMORY_RAW="${_mem:-2Gi}"

    if [[ "$MEMORY_RAW" =~ ^[0-9]+$ ]]; then
        if [ "$MEMORY_RAW" -le 16 ]; then MEMORY="${MEMORY_RAW}Gi"; else MEMORY="${MEMORY_RAW}Mi"; fi
    else
        MEMORY="$MEMORY_RAW"
    fi

    if [[ "$CPU" == "4" && ( "$MEMORY" == "512Mi" || "$MEMORY" == "1Gi" ) ]]; then
        MEMORY="2Gi"
        echo -e "\033[1;33m⚠️ Auto-adjusted Memory to 2Gi (Required for 4 CPUs)\033[0m"
    fi

    # --- Internal Configuration ---
    PROJECT_NUM=$(gcloud projects describe "$PROJECT_ID" --format='value(projectNumber)')

    deploy_service() {
        local TYPE=$1
        local NAME=$2
        local IMG=$3
        
        echo -e "\033[1;33m🚀 Initializing $TYPE Deployment [$NAME]...\033[0m"
        
        (gcloud run deploy "$NAME" \
            --image="$IMG" \
            --platform=managed \
            --region="$REGION" \
            --cpu="$CPU" \
            --memory="$MEMORY" \
            --no-cpu-throttling \
            --allow-unauthenticated \
            --port=8080 \
            --min-instances=1 \
            --timeout=3600 \
            --concurrency=1000 \
            --quiet > /dev/null 2>&1) &
        
        local DEPLOY_PID=$!
        disown $DEPLOY_PID
        local COUNT=0
        
        while ps -p $DEPLOY_PID > /dev/null; do
            if [ $COUNT -lt 98 ]; then
                ((COUNT+=2))
            fi
            echo -ne "\r\033[1;36m[Progress: ${COUNT}%]\033[0m Deploying resources to Google Cloud..."
            sleep 1
        done
        
        echo -ne "\r\033[1;32m[Progress: 100%]\033[0m Deployment Successfully Completed!          \n"
    }

    # --- Execution Phase ---
    banner "⚙️ Execution Phase — Deploying to Cloud"
    TR_URL=""
    VL_URL=""

    if [[ "$PROTO_INPUT" == "1" || "$PROTO_INPUT" == "3" ]]; then
        HOST_TR="${TR_NAME}-${PROJECT_NUM}.${REGION}.run.app"
        deploy_service "Trojan" "$TR_NAME" "docker.io/n4pro/tr:latest"
        TR_URL="trojan://Trojan-2025@firebase-settings.crashlytics.com:443?path=%2FN4&security=tls&type=ws&sni=cares.paymaya.com&host=${HOST_TR}#${TR_NAME}"
    fi

    if [[ "$PROTO_INPUT" == "2" || "$PROTO_INPUT" == "3" ]]; then
        HOST_VL="${VL_NAME}-${PROJECT_NUM}.${REGION}.run.app"
        VLESS_UUID="0c890000-4733-b20e-067f-fc341bd20000"
        deploy_service "Vless" "$VL_NAME" "docker.io/n4pro/vl:latest"
        VL_URL="vless://${VLESS_UUID}@firebase-settings.crashlytics.com:443?path=%2FN4&security=tls&encryption=none&host=${HOST_VL}&type=ws&sni=cares.paymaya.com#${VL_NAME}"
    fi

    # --- Final Output ---
    echo -e "\n================================================"
    ok "DEPLOYMENT COMPLETED"
    echo "================================================"
    if [ ! -z "$TR_URL" ]; then
        echo "🔗 TROJAN IMPORT LINK:"
        echo -e "\033[1;32m$TR_URL\033[0m"
        echo "------------------------------------------------"
    fi
    if [ ! -z "$VL_URL" ]; then
        echo "🔗 VLESS IMPORT LINK:"
        echo -e "\033[1;32m$VL_URL\033[0m"
        echo "------------------------------------------------"
    fi
    echo -e "\033[1;35m💡 NOTE: SPECIAL THANKS TO N4-PRO FOR THE DOCKERFILE\033[0m"
    echo "================================================"
    
    read -rp "Done. Press [Enter] to return to main menu..." </dev/tty
done
